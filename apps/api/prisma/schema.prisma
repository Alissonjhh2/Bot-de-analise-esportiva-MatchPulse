// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Plan {
  FREE
  PREMIUM
  ENTERPRISE
}

enum StrategyStatus {
  ACTIVE
  INACTIVE
}

enum Visibility {
  PRIVATE
  PUBLIC
}

enum LogLevel {
  ERROR
  WARN
  INFO
  DEBUG
}

enum Indicator {
  GOALS
  CORNERS
  OFFENSIVE_PRESSURE
  SHOTS_ON_GOAL
  CARDS
  FOULS
  OFFSIDES
  BALL_POSSESSION
}

enum Team {
  HOME
  AWAY
  MATCH
}

enum ConditionOperator {
  ANY
  MORE
  LESS
}

// Models
model User {
  id          String   @id @default(uuid())
  firebaseUid String   @unique
  name        String
  email       String   @unique
  avatar      String?
  role        Role     @default(USER)
  plan        Plan     @default(FREE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  strategies              Strategy[]
  telegramConnection      TelegramConnection?
  telegramLinkCodes       TelegramLinkCode[]
  notificationHistories    NotificationHistory[]

  @@index([firebaseUid])
  @@index([email])
}

model TelegramConnection {
  id          String   @id @default(uuid())
  userId      String   @unique
  chatId      String   @unique
  username    String?
  firstName   String?
  connectedAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chatId])
}

model TelegramLinkCode {
  id        String   @id @default(uuid())
  code      String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@index([expiresAt])
}

model Strategy {
  id          String             @id @default(uuid())
  userId      String
  name        String
  description String?
  startMinute Int                @default(1)
  endMinute   Int                @default(90)
  status      StrategyStatus     @default(ACTIVE)
  visibility  Visibility         @default(PRIVATE)
  leagues     String[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Relations
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  conditions        StrategyCondition[]
  notificationHistories NotificationHistory[]
  matchHits         MatchHit[]

  @@index([userId])
  @@index([status])
  @@index([visibility])
}

model StrategyCondition {
  id         String             @id @default(uuid())
  strategyId String
  indicator  Indicator
  team       Team
  quantity   Int
  operator   ConditionOperator
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  // Relations
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([strategyId])
  @@index([indicator])
}

model NotificationHistory {
  id           String   @id @default(uuid())
  userId       String
  strategyId   String
  matchName    String
  championship String
  message      String
  sentAt       DateTime @default(now())

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([strategyId])
  @@index([sentAt])
}

model MatchHit {
  id          String   @id @default(uuid())
  matchId     String
  strategyId  String
  minute      Int
  result      Boolean  @default(true)
  snapshot    Json
  createdAt   DateTime @default(now())

  // Relations
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([strategyId])
  @@index([minute])
  @@index([createdAt])
}

model Log {
  id        String   @id @default(uuid())
  level     LogLevel
  source    String
  message   String
  details   Json?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
}

// Cost Weights for Event Cost Engine
model CostWeights {
  id                 String  @id @default(uuid())
  leagueWeight       Float   @default(1.0)
  conditionWeight    Float   @default(1.0)
  indicatorWeight    Float   @default(1.0)
  apiWeight          Float   @default(1.0)
  eventWeight        Float   @default(1.0)
  notificationWeight Float   @default(1.0)
  frequencyWeight    Float   @default(1.0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// User Budget for Resource Budget System
model UserBudget {
  id           String   @id @default(uuid())
  userId       String   @unique
  totalBudget  Int      // Total computational budget
  usedBudget   Int      @default(0)
  plan         Plan
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([plan])
}

// Strategy Complexity Score
model StrategyComplexity {
  id           String   @id @default(uuid())
  strategyId   String   @unique
  complexityScore Int
  leagueCost   Int
  conditionCost Int
  indicatorCost Int
  apiCost      Int
  eventCost    Int
  notificationCost Int
  frequencyCost Int
  calculatedAt DateTime @default(now())

  @@index([strategyId])
  @@index([complexityScore])
}

// Strategy Fingerprint for Fingerprint Engine
model StrategyFingerprint {
  id          String   @id @default(uuid())
  strategyId  String   @unique
  fingerprint String
  similarityGroup String? // Group ID for similar strategies
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fingerprint])
  @@index([similarityGroup])
}

// Audit Log for security events
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  resource    String
  resourceId  String?
  ipAddress   String?
  userAgent   String?
  details     Json?
  success     Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@index([ipAddress])
}
